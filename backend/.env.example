APP_ENV=dev
APP_NAME=undercover-backend

# Comma-separated origins allowed to call backend (CORS).
# If you access frontend via LAN IP (e.g. http://192.168.xx.xx:3000), you must add it here.
# Example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.31.16:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: allow origins by regex (useful for LAN access). Example allows any port on 192.168.31.*
# Default in code already covers all private IPs (192.168.*, 10.*, 172.16-31.*).
# Only uncomment to override:
# CORS_ORIGIN_REGEX=^http://192\\.168\\.31\\.\\d{1,3}(:\\d+)?$

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DB=undercover

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Optional
LOG_LEVEL=INFO
